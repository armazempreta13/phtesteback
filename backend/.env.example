# JWT - NEVER use default values in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Admin credentials (used only for initial seed)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# AI (OpenRouter)
AI_API_KEY=
AI_MODEL=qwen/qwen3.6-plus:free

# Webhook Secret for payment verification
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=

# CORS - comma-separated allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:4000

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Formspree (optional fallback)
FORMSPREE_ENDPOINT=

# Node environment
NODE_ENV=development
PORT=4000
