{
  "name": "phstatic-backend",
  "version": "3.0.0",
  "description": "Backend Robusto para PH.dev Platform (Cloudflare Workers + Express)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:workers": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:dry": "wrangler deploy --dry-run",
    "cf:seed": "node scripts/seed_admin_cf.js",
    "workers:dev": "wrangler dev --local"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.14",
    "nodemon": "^3.1.4",
    "qrcode": "^1.5.4",
    "sqlite3": "^5.1.7",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250303.0",
    "hono": "^4.7.0",
    "hono-rate-limiter": "^0.4.0",
    "@node-rs/argon2": "^2.0.0",
    "typescript": "^5.8.2",
    "wrangler": "^4.6.0"
  }
}
